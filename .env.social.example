# ============================================
# 社交培训系统 - 独立环境配置
# 与心理咨询师培训系统完全隔离
# ============================================

# ============================================
# Supabase 配置（独立项目）
# ============================================
# 重要：请为社交培训系统创建一个新的 Supabase 项目
# 不要与心理咨询师培训系统共用同一个项目
#
# 获取方式：
# 1. 登录 https://supabase.com
# 2. 创建一个新项目，命名为 "social-training" 或类似名称
# 3. 进入 Settings → API
# 4. 复制 Project URL 和 anon/public key
# 5. 在 SQL Editor 中执行 social_training_schema.sql 创建表结构
#
VITE_SUPABASE_URL=https://your-social-training-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-social-project-anon-key-here

# ============================================
# Dify API 网关配置（社交培训专用）
# ============================================
# 注意：这些 API Key 需要为社交培训场景单独配置

# 场景伙伴 AI（根据场景扮演不同角色：面试官、客户、约会对象等）
VITE_SOCIAL_DIFY_PARTNER_API_URL=https://gateway.lingxinai.com/dify-test/v1
VITE_SOCIAL_DIFY_PARTNER_API_KEY=your-partner-agent-key

# 社交技能评估 AI（分析沟通能力、情商表达、说服力等）
VITE_SOCIAL_DIFY_EVALUATOR_API_URL=https://gateway.lingxinai.com/dify-test/v1
VITE_SOCIAL_DIFY_EVALUATOR_API_KEY=your-evaluator-agent-key

# 综合反馈 Agent（可选，用于生成整体建议）
VITE_SOCIAL_DIFY_FEEDBACK_API_URL=https://gateway.lingxinai.com/dify-test/v1
VITE_SOCIAL_DIFY_FEEDBACK_API_KEY=

# ============================================
# 应用配置
# ============================================
VITE_APP_TITLE=社交技能培训系统
VITE_APP_MODE=social  # 标识为社交培训模式

# ============================================
# 可用的社交场景类型
# ============================================
# interview - 求职面试
# negotiation - 商务谈判
# dating - 约会社交
# presentation - 公开演讲
# networking - 社交网络
# conflict_management - 冲突管理
# team_leadership - 团队领导
# customer_service - 客户服务
