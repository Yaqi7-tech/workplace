# ============================================
# Supabase 配置（数据库功能）
# ============================================
# 获取方式：
# 1. 登录 https://supabase.com
# 2. 创建项目后，进入 Settings → API
# 3. 复制 Project URL 和 anon/public key
#
# 如果不配置 Supabase，系统将使用模拟登录模式
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ============================================
# Dify API 网关配置
# ============================================
# 注意：已切换到新网关地址

# 访客AI (来访者角色) API配置
VITE_DIFY_VISITOR_API_URL=https://gateway.lingxinai.com/dify-test/v1
VITE_DIFY_VISITOR_API_KEY=app-2HjDhAbbHNl8N4T2Rcs2C25s

# 督导AI API配置
VITE_DIFY_SUPERVISOR_API_URL=https://gateway.lingxinai.com/dify-test/v1
VITE_DIFY_SUPERVISOR_API_KEY=app-3NPjpb7nkYhFAYtXpFvOShv6

# 综合评价 Agent（可选）
VITE_DIFY_API_OVERALL_URL=https://gateway.lingxinai.com/dify-test/v1
VITE_DIFY_API_OVERALL_KEY=

# 应用标题
VITE_APP_TITLE=培训评测系统

# 应用模式：counseling（心理咨询师培训）或 workplace（职场培训）
VITE_APP_MODE=counseling

# ============================================
# 职场 NPC 模拟培训系统 API 配置
# ============================================
# 带教老师/上级 NPC API（扮演不同人设与学员对话）
VITE_SOCIAL_DIFY_PARTNER_API_URL=https://api.dify.ai/v1
VITE_SOCIAL_DIFY_PARTNER_API_KEY=your-workplace-npc-api-key

# 职场技能评估 API（可选，用于AI自动评估）
VITE_SOCIAL_DIFY_EVALUATOR_API_URL=https://api.dify.ai/v1
VITE_SOCIAL_DIFY_EVALUATOR_API_KEY=your-workplace-evaluator-api-key

# ============================================
# API 地址映射说明：
# ============================================
# https://dify.ai-role.cn/v1 -> https://gateway.lingxinai.com/dify-test/v1 (测试环境)
# http://dify.lingxinai.com/v1 -> https://gateway.lingxinai.com/dify-prod/v1 (生产环境)
# https://api.dify.ai/v1 -> Dify 官方 API 地址
